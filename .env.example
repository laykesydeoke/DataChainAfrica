# DataChainAfrica environment variables
# Copy this file to .env and fill in the values

# Stacks network (testnet | mainnet)
STACKS_NETWORK=testnet

# Hiro API base URL
STACKS_API_URL=https://api.testnet.hiro.so

# Contract deployer address (your STX wallet address)
DEPLOYER_ADDRESS=

# Contract names
BILLING_CONTRACT=billing
DATA_TRACKING_CONTRACT=data-tracking
MARKETPLACE_CONTRACT=marketplace
DATA_TRAITS_CONTRACT=data-traits
