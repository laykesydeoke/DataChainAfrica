# DataChainAfrica environment variables
# Copy this file to .env and fill in the values

# Stacks network (testnet | mainnet)
STACKS_NETWORK=testnet

# Hiro API base URL
STACKS_API_URL=https://api.testnet.hiro.so

# Contract deployer address (your STX wallet address)
DEPLOYER_ADDRESS=

# Contract names
BILLING_CONTRACT=billing
DATA_TRACKING_CONTRACT=data-tracking
MARKETPLACE_CONTRACT=marketplace
DATA_TRAITS_CONTRACT=data-traits

# Analytics
ANALYTICS_REFRESH_INTERVAL_MS=30000
ENABLE_ANALYTICS_DASHBOARD=true

# Marketplace
DEFAULT_PLATFORM_FEE_PCT=2
MAX_PLATFORM_FEE_PCT=10
DEFAULT_LISTING_DURATION_BLOCKS=500

# Grace Period (blocks)
DEFAULT_GRACE_PERIOD_BLOCKS=144

# Subscription Management
ALLOW_SELF_CANCEL=true
CANCEL_GRACE_BLOCKS=144
SHOW_GRACE_COUNTDOWN=true
GRACE_WARNING_THRESHOLD_BLOCKS=72

# Carrier Integration
CARRIER_ADDRESS=
CARRIER_REPORTING_INTERVAL_BLOCKS=12
CARRIER_STATS_DISPLAY=true
CARRIER_STATS_REFRESH_MS=60000
MAX_CARRIERS=10

# Marketplace V2
ENABLE_LISTING_EXTENSION=true
MAX_EXTENSION_BLOCKS=2000
MIN_EXTENSION_BLOCKS=1

# Marketplace Analytics
SHOW_MARKETPLACE_OVERVIEW=true
ANALYTICS_AUTO_REFRESH=true
MARKETPLACE_STATS_POLL_MS=30000

# Subscription Tracking
TRACK_SUBSCRIPTION_AGE=true
AGE_DISPLAY_UNIT=blocks

# Active Subscription Verification
ACTIVE_SUB_CHECK_ENABLED=true
SUB_EXPIRY_BUFFER_BLOCKS=10

# Indexing
INDEXER_BACKEND_URL=
INDEXER_POLL_INTERVAL_MS=15000
CHAINHOOK_ENABLED=false
CHAINHOOK_WEBHOOK_URL=

# Billing Enhanced
SHOW_PAYMENT_HISTORY=true
PAYMENT_HISTORY_LIMIT=10
REVENUE_DISPLAY_DECIMALS=2

# Analytics Overview
ANALYTICS_PAGE_TITLE=DataChain Analytics
ANALYTICS_CACHE_TTL_MS=30000
SHOW_CARRIER_ANALYTICS=true

# Governance
GOVERNANCE_DASHBOARD_ENABLED=true
SHOW_PLAN_EXPIRY=true
SHOW_AUTO_RENEW_STATUS=true
GOVERNANCE_REFRESH_MS=60000
ENABLE_PLAN_DEACTIVATION=true
ENABLE_CARRIER_REVOCATION=true

# Compliance
COMPLIANCE_MODE=ndpc
DATA_CONTROLLER_ADDRESS=
CONSENT_REQUIRED=true
AUDIT_LOG_ENABLED=true

# Telemetry
TELEMETRY_ENABLED=true
TELEMETRY_REFRESH_MS=30000
TELEMETRY_SNAPSHOT_ENABLED=true
TELEMETRY_EXPORT_ENABLED=false
TELEMETRY_EXPORT_FORMAT=json
TELEMETRY_EXPORT_PATH=./telemetry-exports/
SHOW_NETWORK_TELEMETRY=true
SHOW_USER_TELEMETRY=true
METRICS_DASHBOARD_ENABLED=true
STAKING_ENABLED=true
BASE_REWARD_RATE=50
NODE_REGISTRY_OPEN=true
NODE_REWARD_ENABLED=true
BOUNTY_SYSTEM_ENABLED=true
MIN_BOUNTY_REWARD=1
